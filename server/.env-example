# Variables d'environnement du serveur
#
# Copier ce fichier en .env.development.local et remplir les valeurs.
# .env.development.local est gitignoré et ne doit jamais être commité.
#
#   cp server/.env-example server/.env.development.local

# Port d'écoute du serveur HTTP (par défaut 3000)
PORT=3000

# Environnement Node. Affecte le format des logs (pretty en dev, JSON en prod)
# et les options du cookie JWT (SameSite=None + Secure en prod pour le cross-site)
NODE_ENV=development

# ----- Base de données MongoDB -----
#
# Deux options possibles :
#
# 1. MongoDB Atlas (recommandé, et c'est ce qu'on utilise en prod)
#    Créer un cluster gratuit sur https://cloud.mongodb.com,
#    ajouter un user en readWrite sur la base crypto_portfolio,
#    autoriser son IP dans Network Access, puis copier la connection
#    string depuis Connect > Drivers > Node.js.
#
#    Format : mongodb+srv://<user>:<password>@<cluster>.mongodb.net/crypto_portfolio?retryWrites=true&w=majority
#
#    Attention : si le mot de passe contient des caractères spéciaux
#    (* ? @ / etc.), il faut les URL-encoder (* devient %2A par exemple).
#    Et ne pas oublier d'ajouter /crypto_portfolio avant le ? sinon
#    Mongoose écrit dans la base "test" par défaut.
#
# 2. MongoDB local via Docker (utile hors ligne)
#    Lancer docker compose up -d depuis la racine.
#    Le user crypto_app est créé automatiquement par mongo-init/init.js.
#
#    Format : mongodb://crypto_app:dev_password_2026@localhost:35115/crypto_portfolio?authSource=crypto_portfolio
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/crypto_portfolio?retryWrites=true&w=majority

# URL publique du serveur (sert à construire les liens de validation email)
APP_BASE_URL=http://localhost:3000

# Origines autorisées par CORS, séparées par des virgules.
# Doit contenir l'URL du front (localhost:5173 en dev, l'URL Netlify en prod).
CORS_ORIGIN=http://localhost:5173

# Clé secrète pour signer les JWT. Doit être une longue chaîne aléatoire.
# Générer avec : node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-in-development

# Nom du cookie qui contient le JWT
JWT_COOKIE_NAME=token

# ----- Envoi d'emails (optionnel) -----
#
# Si SMTP_HOST, SMTP_USER et SMTP_PASS sont tous renseignés, les emails
# de validation sont envoyés pour de vrai. Sinon, le mailer retombe sur
# un transport JSON et en mode dev le token de validation est renvoyé
# directement dans la réponse de /auth/register (pratique pour tester
# sans SMTP).
#
# Exemple Gmail (nécessite un App Password à 16 caractères) :
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=mon-email@gmail.com
#   SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=no-reply@crypto-portfolio.local
