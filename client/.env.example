# Variables d'environnement du client
#
# Copier ce fichier en .env.development.local et ajuster si besoin.
#
#   cp client/.env.example client/.env.development.local
#
# Attention : Vite n'expose au code client que les variables préfixées
# par VITE_. Leur valeur est embarquée dans le bundle au moment du build,
# donc ne jamais y mettre de secret.

# URL de base de l'API backend.
# - en dev : http://localhost:3000 (ou le PORT utilisé par le serveur)
# - en prod (Netlify) : URL Render de l'API, à définir dans les variables
#   d'environnement du site Netlify
VITE_API_BASE_URL=http://localhost:3000
